# ============================================
# PYTHON CACHE FILES
# ============================================
__pycache__/
*.py[cod]
*$py.class

# ============================================
# VIRTUAL ENVIRONMENTS
# ============================================
venv/
env/
.venv/
ENV/

# ============================================
# ENVIRONMENT VARIABLES (IMPORTANT)
# ============================================
.env
.env.*
*.env

# ============================================
# LOG FILES
# ============================================
*.log
logs/
*.out

# ============================================
# MODEL FILES (Large - Do Not Upload)
# ============================================
*.pt
*.onnx
*.engine
models/
weights/

# ============================================
# DATASETS & VIDEOS (Large Files)
# ============================================
data/
datasets/
*.mp4
*.avi
*.mov
*.mkv

# ============================================
# JUPYTER NOTEBOOKS CHECKPOINTS
# ============================================
.ipynb_checkpoints/

# ============================================
# IDE / EDITOR FILES
# ============================================
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ============================================
# OPERATING SYSTEM FILES
# ============================================
.DS_Store
Thumbs.db

# ============================================
# BUILD / DIST FILES
# ============================================
build/
dist/
*.egg-info/
.eggs/

# ============================================
# TEST & COVERAGE
# ============================================
.pytest_cache/
.coverage
htmlcov/

# # ============================================
# # DOCKER (Optional)
# # ============================================
# docker-compose.override.yml